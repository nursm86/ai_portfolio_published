// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Scrolling "What I'm up to" cards on the landing page.
/// Clicking a chip routes into the chat with `chatPrompt` (or `label` if null)
/// pre-filled as the user query. `href` is only for external/non-chat routes
/// like /hex — prefer chatPrompt for everything else so the whole site stays
/// chat-first.
model Activity {
  id         Int      @id @default(autoincrement())
  label      String
  iconName   String
  color      String
  href       String?
  chatPrompt String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Quick-question buttons (Me / Projects / Skills / Contact) — single source for landing, chat-landing, HelperBoost
model QuestionCard {
  id       Int    @id @default(autoincrement())
  key      String @unique
  prompt   String
  iconName String
  color    String
  order    Int    @default(0)
}

/// Rotating hero titles under the "Hey, I'm Nur 👋" header
model HeroTitle {
  id    Int    @id @default(autoincrement())
  text  String
  order Int    @default(0)
}

/// FAQ entries surfaced by the getFAQ chat tool
model FAQ {
  id       Int    @id @default(autoincrement())
  question String
  answer   String
  order    Int    @default(0)
}

/// Availability — singleton row (id always 1)
model AvailabilityEntry {
  id        Int      @id @default(1)
  status    String
  headline  String
  detailsMd String
  timezone  String   @default("AEST (UTC+10)")
  updatedAt DateTime @updatedAt
}

/// Day-to-day stack items surfaced by the getStack chat tool
model StackItem {
  id       Int     @id @default(autoincrement())
  category String
  name     String
  note     String?
  order    Int     @default(0)
}

/// Portfolio project / case study. One Project -> many screenshots and links.
/// Rendered both in chat (via getProjects tool -> Apple card grid) and on
/// a dedicated /projects/[slug] scroll-driven detail page.
model Project {
  id             Int            @id @default(autoincrement())
  slug           String         @unique
  title          String
  category       String
  tagline        String
  coverImage     String?
  date           String
  order          Int            @default(0)
  featured       Boolean        @default(true)

  // Markdown story sections. Empty string -> section hidden on the page.
  problemMd      String         @default("")
  solutionMd     String         @default("")
  architectureMd String         @default("")
  impactMd       String         @default("")

  // JSON-encoded array of tech stack chips (SQLite has no array type).
  techStack      String         @default("[]")

  // Optional chat query fired from the "Ask me anything about this" CTA.
  chatPrompt     String?

  images         ProjectImage[]
  links          ProjectLink[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

/// Screenshot or diagram attached to a project.
model ProjectImage {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  src       String
  alt       String
  caption   String?
  width     Int?
  height    Int?
  layout    String  @default("wide") // "wide" | "half" | "mobile"
  order     Int     @default(0)
}

/// External link attached to a project (live demo, GitHub, case study PDF, etc.).
model ProjectLink {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
  iconName  String?
  order     Int     @default(0)
}
